{
  "dev": {
    "driver": "pg",
    "host": {"ENV": "DB_HOST"},
    "database": {"ENV": "DB_NAME"},
    "user": {"ENV": "DB_USER"},
    "password": {"ENV": "DB_PASSWORD"},
    "port": {"ENV": "DB_PORT"},
    "schema": "public",
    "ssl": {
      "rejectUnauthorized": false
    }
  },
  "production": {
    "driver": "pg",
    "connectionString": {"ENV": "DATABASE_URL"},
    "ssl": {
      "rejectUnauthorized": false
    }
  }
}
